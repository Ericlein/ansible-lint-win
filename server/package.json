{
  "name": "ansible-lint-win",
  "version": "0.1.3",
  "description": "Windows-native Ansible language server — no Python required",
  "main": "dist/server.js",
  "files": [
    "dist",
    "data",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "bundle": "esbuild src/server.ts --bundle --platform=node --outfile=dist/server.js --format=cjs",
    "dev": "tsc --watch",
    "start": "node dist/server.js --stdio",
    "generate-data": "tsx ../scripts/generate-module-data.ts",
    "test": "vitest run",
    "copy-meta": "node -e \"require('fs').copyFileSync('../README.md','README.md');require('fs').copyFileSync('../LICENSE','LICENSE')\"",
    "prepublishOnly": "npm run copy-meta && npm run build && npm run bundle"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ericlein/ansible-lint-win.git"
  },
  "homepage": "https://github.com/Ericlein/ansible-lint-win#readme",
  "bugs": {
    "url": "https://github.com/Ericlein/ansible-lint-win/issues"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "ansible",
    "ansible-lint",
    "language-server",
    "lsp",
    "yaml",
    "windows",
    "zed"
  ],
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^25.7.0",
    "esbuild": "^0.27.7",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12",
    "yaml": "^2.9.0"
  }
}
