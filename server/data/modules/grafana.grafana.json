        "required": false,
        "choices": null,
        "default": [],
        "aliases": null
      },
      "muteTimeIntervals": {
        "description": "List of string. Sets the mute timing for the notfification policy.",
        "type": "list",
        "required": false,
        "choices": null,
        "default": [],
        "aliases": null
      },
