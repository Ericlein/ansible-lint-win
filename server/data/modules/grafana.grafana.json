  "grafana.grafana.alert_notification_policy": {
    "short_description": "Manage Alerting Policies points in Grafana",
    "description": "Set the notification policy tree using Ansible.",
    "options": {
      "Continue": {
        "description": "Continue matching subsequent sibling nodes if set to C(true).",
