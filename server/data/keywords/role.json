{
  "role": { "description": "Name of the role to apply", "type": "string", "required": true },
  "vars": { "description": "Variables to pass to the role", "type": "dict", "required": false },
  "when": { "description": "Conditional for applying the role", "type": "string", "required": false },
  "become": { "description": "Privilege escalation for this role", "type": "bool", "required": false },
  "become_user": { "description": "Escalation user for this role", "type": "string", "required": false },
  "tags": { "description": "Tags for the role", "type": "list", "required": false },
  "environment": { "description": "Environment variables for role tasks", "type": "dict", "required": false },
  "delegate_to": { "description": "Delegate all role tasks to another host", "type": "string", "required": false },
  "any_errors_fatal": { "description": "Abort on any failure in this role", "type": "bool", "required": false }
}
