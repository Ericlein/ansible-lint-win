{
  "name": { "description": "Human-readable name for the task", "type": "string", "required": false },
  "register": { "description": "Store task result in a variable", "type": "string", "required": false },
  "when": { "description": "Conditional expression (Jinja2, evaluated as boolean)", "type": "string", "required": false },
  "loop": { "description": "Iterate over a list", "type": "list", "required": false },
  "loop_control": { "description": "Control loop behavior (label, pause, index_var, etc.)", "type": "dict", "required": false },
  "with_items": { "description": "Iterate over a list (legacy, prefer loop)", "type": "list", "required": false },
  "with_dict": { "description": "Iterate over a dictionary (legacy)", "type": "dict", "required": false },
  "with_fileglob": { "description": "Iterate over file patterns (legacy)", "type": "list", "required": false },
  "notify": { "description": "Trigger one or more handlers on change", "type": "list", "required": false },
  "become": { "description": "Enable privilege escalation for this task", "type": "bool", "required": false },
  "become_user": { "description": "User to escalate to for this task", "type": "string", "required": false },
  "tags": { "description": "Tags for selective task execution", "type": "list", "required": false },
  "ignore_errors": { "description": "Continue on task failure", "type": "bool", "required": false },
  "failed_when": { "description": "Custom failure condition", "type": "string", "required": false },
  "changed_when": { "description": "Custom change detection condition", "type": "string", "required": false },
  "retries": { "description": "Number of times to retry on failure", "type": "int", "required": false },
  "delay": { "description": "Seconds to wait between retries", "type": "int", "required": false },
  "until": { "description": "Retry until this condition is true", "type": "string", "required": false },
  "delegate_to": { "description": "Run task on a different host", "type": "string", "required": false },
  "delegate_facts": { "description": "Assign facts to delegated host", "type": "bool", "required": false },
  "run_once": { "description": "Execute task only once across all hosts", "type": "bool", "required": false },
  "no_log": { "description": "Suppress logging of sensitive data", "type": "bool", "required": false },
  "environment": { "description": "Environment variables for this task", "type": "dict", "required": false },
  "vars": { "description": "Task-scoped variables", "type": "dict", "required": false },
  "args": { "description": "Alternative way to pass module arguments", "type": "dict", "required": false },
  "check_mode": { "description": "Force or disable check mode for this task", "type": "bool", "required": false },
  "diff": { "description": "Show diff of changes", "type": "bool", "required": false },
  "connection": { "description": "Connection plugin override for this task", "type": "string", "required": false },
  "timeout": { "description": "Connection timeout override", "type": "int", "required": false },
  "throttle": { "description": "Limit concurrent workers for this task", "type": "int", "required": false },
  "async": { "description": "Maximum time (seconds) for async task", "type": "int", "required": false },
  "poll": { "description": "Polling interval for async tasks (0 = fire-and-forget)", "type": "int", "required": false },
  "listen": { "description": "Handler topic to subscribe to (handlers only)", "type": "string", "required": false }
}
