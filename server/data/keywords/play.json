{
  "hosts": { "description": "Target hosts or host groups to run against", "type": "string", "required": true },
  "become": { "description": "Enable privilege escalation", "type": "bool", "required": false },
  "become_user": { "description": "User to escalate to (default: root)", "type": "string", "required": false },
  "become_method": { "description": "Privilege escalation method (sudo, su, etc.)", "type": "string", "required": false },
  "gather_facts": { "description": "Whether to run the setup module on hosts", "type": "bool", "required": false },
  "vars": { "description": "Dictionary of variables for this play", "type": "dict", "required": false },
  "vars_files": { "description": "List of files containing variables", "type": "list", "required": false },
  "vars_prompt": { "description": "List of variables to prompt for", "type": "list", "required": false },
  "roles": { "description": "List of roles to apply", "type": "list", "required": false },
  "tasks": { "description": "List of tasks to execute", "type": "list", "required": false },
  "pre_tasks": { "description": "Tasks to execute before roles", "type": "list", "required": false },
  "post_tasks": { "description": "Tasks to execute after roles", "type": "list", "required": false },
  "handlers": { "description": "Handler definitions triggered by notify", "type": "list", "required": false },
  "environment": { "description": "Environment variables for all tasks", "type": "dict", "required": false },
  "collections": { "description": "List of collections to search for modules", "type": "list", "required": false },
  "serial": { "description": "Number or percentage of hosts to process at a time", "type": "string", "required": false },
  "max_fail_percentage": { "description": "Maximum percentage of hosts that can fail before aborting", "type": "int", "required": false },
  "any_errors_fatal": { "description": "Abort the play on any task failure", "type": "bool", "required": false },
  "ignore_errors": { "description": "Continue execution on task errors", "type": "bool", "required": false },
  "ignore_unreachable": { "description": "Ignore unreachable hosts and continue", "type": "bool", "required": false },
  "strategy": { "description": "Execution strategy: linear, free, debug", "type": "string", "required": false },
  "connection": { "description": "Connection plugin: ssh, local, winrm, etc.", "type": "string", "required": false },
  "tags": { "description": "Tags for selective execution", "type": "list", "required": false },
  "name": { "description": "Name of the play (shown in output)", "type": "string", "required": false },
  "no_log": { "description": "Suppress logging of task data", "type": "bool", "required": false },
  "force_handlers": { "description": "Run handlers even if a task fails", "type": "bool", "required": false },
  "module_defaults": { "description": "Default parameters for modules", "type": "dict", "required": false },
  "order": { "description": "Host execution order: inventory, reverse_inventory, sorted, reverse_sorted, shuffle", "type": "string", "required": false },
  "throttle": { "description": "Limit number of concurrent task workers", "type": "int", "required": false },
  "timeout": { "description": "Connection timeout in seconds", "type": "int", "required": false }
}
